# PostgreSQL (optional - defaults shown)
DB_ENGINE=postgresql
DB_NAME=ahtak
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432


# Frontend URL (for root redirect and email links)
FRONTEND_URL=https://ahttak.or.ke
ALLOWED_HOSTS=localhost,127.0.0.1,ahttak.or.ke,www.ahttak.or.ke
CSRF_TRUSTED_ORIGINS=https://ahttak.or.ke,https://www.ahttak.or.ke,http://localhost:5173,http://127.0.0.1:5173
# Used by frontend SEO utility at build time:
# VITE_SITE_URL=https://ahttak.or.ke

# Email (for welcome/approval and notifications)
# Dev: leave console backend (emails print in the terminal only).
# Prod: SMTP (example: mail.ahttak.or.ke on port 587 with STARTTLS)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=info@ahttak.or.ke
# EMAIL_HOST=mail.ahttak.or.ke
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=info@ahttak.or.ke
# EMAIL_HOST_PASSWORD=your-mailbox-password
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@ahtak.local

# Seed (python manage.py seed_db --no-input)
# SEED_USERNAME=admin
# SEED_PASSWORD=admin123
# SEED_EMAIL=admin@ahtak.local
